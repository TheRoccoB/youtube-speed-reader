{
  "manifest_version": 3,
  "name": "Rivet — YouTube speed reader",
  "version": "0.13.5",
  "description": "RSVP-style YouTube caption reader. Rivet pins the optimal-recognition-point letter in red so your eyes stay anchored.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://youtube.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["probe.js"],
      "matches": [
        "https://*.youtube.com/*",
        "https://youtube.com/*"
      ]
    }
  ]
}
