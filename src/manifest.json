{
  "manifest_version": 3,
  "name": "YouTube Speed Reader",
  "version": "0.10.10",
  "description": "Read YouTube captions one word at a time, RSVP-style with ORP highlighting.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://youtube.com/*"
  ]
}
